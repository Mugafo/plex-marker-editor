FROM node:22-bookworm-slim

# better-sqlite3 may compile via node-gyp if a prebuild is missing for your platform.
RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json* ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

# Fail the image build if the native module is missing or broken
RUN node -e "require('better-sqlite3')"

COPY tsconfig.json ./
COPY src ./src

EXPOSE 3101
CMD ["./node_modules/.bin/nodemon", "--legacy-watch", "--watch", "src", "--ext", "ts", "--exec", "./node_modules/.bin/tsx ./src/index.ts"]
